{
  "manifest_version": 3,
  "name": "Site Notes Overlay",
  "version": "2.0.0",
  "description": "Sticky notes for any website — multiple color-coded notes per site, synced across your devices, in a translucent overlay.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting", "contextMenus", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-notes": {
      "suggested_key": {
        "default": "Alt+N"
      },
      "description": "Show or hide the notes overlay"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Site Notes",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
